# OpenFrame M1 pseudo-netlist
# This is not a PCB file. It is a connectivity contract for schematic capture.

NET VIN_24V           PSU24.J1.1  CTRL.JPWR.1  HV.JIN.1  MOTOR_DRV.JVM.1  FAN.J1.1
NET GND_POWER         PSU24.J1.2  CTRL.JPWR.2  HV.JIN.2  MOTOR_DRV.JVM.2  FAN.J1.2
NET VDD_5V            BUCK5.OUT   CTRL.J5V.1   LEDBAR.JLOGIC.1  SENSOR_BANK.JVCC.1
NET VDD_3V3           BUCK33.OUT  MCU.3V3      LEVELSHIFT.JLV.1
NET GND_LOGIC         BUCK33.GND  MCU.GND      SENSOR_BANK.GND  LEDBAR.GND

NET COVER_LOOP_OK     INTERLOCK.OUT CTRL.JSAFE.1 MCU.GP28 HV.GATE_IN LED_GATE.IN FUSER_GATE.IN
NET HV_ENABLE_REQ     MCU.GP14      HV_GATE.REQ
NET HV_ENABLE_ACTUAL  HV_GATE.OUT   HV.ENABLE
NET HV_CHARGE_PWM     MCU.GP15      HV.CHARGE_CMD
NET HV_DEV_PWM        MCU.GP16      HV.DEV_CMD
NET HV_TRANSFER_PWM   MCU.GP17      HV.TRANSFER_CMD
NET HV_FAULT          HV.FAULT      MCU.GP27

NET LED_DATA          MCU.GP9       LEDBAR.DATA
NET LED_CLK           MCU.GP10      LEDBAR.CLK
NET LED_LATCH         MCU.GP11      LEDBAR.LATCH
NET LED_STROBE_REQ    MCU.GP12      LED_GATE.STROBE_REQ
NET LED_OE_REQ        MCU.GP13      LED_GATE.OE_REQ
NET LED_OE_ACTUAL     LED_GATE.OE   LEDBAR.OE

NET FUSER_HEATER_REQ  MCU.GP18      FUSER_GATE.REQ
NET FUSER_ENABLE      FUSER_GATE.OUT FUSER_PWR.ENABLE
NET NTC_FUSER_ADC     FUSER.NTC     MCU.GP26_A0
NET THERMAL_FUSE_OK   FUSER.FUSE_SENSE FUSER_GATE.FUSE_OK MCU.SAFE_IN

NET MOTOR_PICKUP_STEP MCU.GP2       MOTOR_DRV.PICKUP_STEP
NET MOTOR_PICKUP_DIR  MCU.GP3       MOTOR_DRV.PICKUP_DIR
NET MOTOR_PROC_STEP   MCU.GP4       MOTOR_DRV.PROC_STEP
NET MOTOR_PROC_DIR    MCU.GP5       MOTOR_DRV.PROC_DIR
NET MOTOR_FUSER_STEP  MCU.GP6       MOTOR_DRV.FUSER_STEP
NET MOTOR_FUSER_DIR   MCU.GP7       MOTOR_DRV.FUSER_DIR
NET MOTOR_ENABLE_N    MCU.GP8       MOTOR_DRV.ENABLE_N

NET SENSOR_TRAY       MCU.GP20      SENSOR_TRAY.OUT
NET SENSOR_PICKUP     MCU.GP21      SENSOR_PICKUP.OUT
NET SENSOR_REG        MCU.GP22      SENSOR_REG.OUT
